# ─── Twitch Application ───────────────────────────────────────
# Register at https://dev.twitch.tv/console
# Set OAuth Redirect URL to: http://localhost:4242/auth/twitch/callback
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# ─── Streamer Account ────────────────────────────────────────
# These are populated automatically via the OAuth flow in the dashboard.
# You can also set them manually if you already have tokens.
STREAMER_TWITCH_OAUTH_TOKEN=
STREAMER_TWITCH_REFRESH_TOKEN=

# ─── Bot Account (optional) ──────────────────────────────────
# Only needed if using a separate bot account for moderation.
# Leave blank to use the streamer account for everything.
BOT_TWITCH_OAUTH_TOKEN=
BOT_TWITCH_REFRESH_TOKEN=

# ─── Channel ─────────────────────────────────────────────────
# The Twitch channel name to monitor (lowercase, no #)
BROADCASTER_CHANNEL=

# ─── OpenRouter AI ───────────────────────────────────────────
# Free-tier key for AI-based content filtering.
# Get one at https://openrouter.ai (free, no credit card needed).
OPENROUTER_DEFAULT_API_KEY=

# ─── Dashboard Security ──────────────────────────────────────
# PIN/passcode to access the web dashboard (protects against LAN access)
DASHBOARD_PIN=1234

# ─── Server ──────────────────────────────────────────────────
# Starting port for the dashboard (scans upward if taken)
PORT_RANGE_START=4242
